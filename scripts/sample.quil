# AutoPulseSynth -> Azure Quantum (Rigetti Quil-T) Export
# Gate: X on qubit 0
# Duration: 40.0 ns (40 samples @ 1 GS/s)

DECLARE ro BIT[1]

# --- Hardware frame definition ---
DEFFRAME 0 "xy":
    SAMPLE-RATE: 1000000000.0
    INITIAL-FREQUENCY: 5000000000.0

# --- Custom ML-optimized waveform (40 IQ samples) ---
DEFWAVEFORM autopulse_x_q0:
    0.140601+0.020797i, 0.163887+0.540251i, 0.197887+0.495585i, 0.235651+0.626610i, 0.277826+0.647884i, 0.324580+0.745008i, 0.375016+0.775699i, 0.429452+0.847165i, 0.486388+0.867387i, 0.545919+0.907575i, 0.606100+0.903419i, 0.666764+0.904942i, 0.725654+0.866775i, 0.782436+0.824855i, 0.834718+0.748594i, 0.882179+0.663693i, 0.922519+0.552007i, 0.955643+0.431017i, 0.979572+0.293399i, 0.994638+0.149175i, 0.999363+0.000507i, 0.994638-0.150190i, 0.979572-0.292385i, 0.955643-0.432032i, 0.922519-0.550993i, 0.882179-0.664707i, 0.834718-0.747579i, 0.782436-0.825869i, 0.725654-0.865761i, 0.666764-0.905957i, 0.606100-0.902405i, 0.545919-0.908590i, 0.486388-0.866372i, 0.429452-0.848179i, 0.375016-0.774684i, 0.324580-0.746023i, 0.277826-0.646870i, 0.235651-0.627625i, 0.197887-0.494570i, 0.163887-0.541266i

# --- Gate calibration: override default X with custom pulse ---
DEFCAL X 0:
    PULSE 0 "xy" autopulse_x_q0

# --- Execute and measure ---
X 0
MEASURE 0 ro[0]